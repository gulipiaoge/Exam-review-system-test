{
  "name": "exam-review-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name=exam-review-system --functions-dir=functions",
    "test:regression": "node scripts/regression-test.js",
    "test:regression:update": "node scripts/regression-test.js --update-baseline",
    "test:regression:local": "node scripts/regression-test.js --api-url=http://localhost:8787"
  },
  "dependencies": {
    "echarts": "^5.5.0",
    "element-plus": "^2.7.0",
    "jschardet": "^1.4.1",
    "katex": "^0.16.11",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^3.11.174",
    "pinia": "^2.1.0",
    "tesseract.js": "^5.1.1",
    "uuid": "^9.0.1",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "form-data": "^4.0.6",
    "node-fetch": "^2.7.0",
    "vite": "^5.4.0",
    "wrangler": "^4.104.0"
  }
}
